generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Chat {
  id Int @id @default(autoincrement())
  userId Int
  collId Int
  user User @relation(fields: [userId], references: [id])
  messages Message[]

  @@unique([userId, collId])
}

model Message {
  id Int @id @default(autoincrement())
  text String
  timestamp DateTime @default(now())
  senderId Int
  chatId Int
  senderType String
  chat Chat @relation(fields: [chatId], references: [id])
}

model Picture {
  pictureId Int    @id @default(autoincrement())
  large     String
  medium    String
  thumbnail String
  userId    Int    @unique
  user      User   @relation(fields: [userId], references: [id])
}

model FreelancerSkill {
  skillId      Int        @id @default(autoincrement())
  name         String
  freelancerId Int
  freelancer   Freelancer @relation(fields: [freelancerId], references: [userId])
}

model OrderSkill {
  skillId Int    @id @default(autoincrement())
  name    String @default("")
  orderId Int
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model FavoriteOrder {
  id         Int        @id @default(autoincrement())
  likedOrderId Int        
  timestamp   DateTime   @default(now())
  freelancerId    Int
  freelancer  Freelancer @relation(fields: [freelancerId], references: [userId], onDelete: Cascade)
  order       Order      @relation(fields: [likedOrderId], references: [id], onDelete: Cascade)

  @@unique([freelancerId, likedOrderId])
}

model Favorite {
  id          Int        @id @default(autoincrement())
  likedUserId Int        
  timestamp   DateTime   @default(now())
  clientId    Int
  client      Client     @relation(fields: [clientId], references: [userId], onDelete: Cascade)
  freelancer  Freelancer @relation(fields: [likedUserId], references: [userId], onDelete: Cascade)

  @@unique([clientId, likedUserId])
}

model Response {
  id           Int        @id @default(autoincrement())
  text         String
  createdAt    DateTime   @default(now())
  freelancerId Int
  orderId      Int
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  freelancer   Freelancer @relation(fields: [freelancerId], references: [userId], onDelete: Cascade)
}

model Order {
  id             Int          @id @default(autoincrement())
  title          String
  description    String
  budgetMin      Int
  budgetMax      Int
  category       String
  status         String
  deadlineDays   Int
  createdAt      DateTime     @default(now())
  clientId       Int
  completedById  Int?
  freelancer     Freelancer?  @relation(fields: [completedById], references: [userId], onDelete: Cascade)
  client         Client       @relation(fields: [clientId], references: [userId], onDelete: Cascade)
  skills         OrderSkill[]
  orderResponses Response[]
  favorites      FavoriteOrder[]
}

model User {
  id           Int         @id @default(autoincrement())
  role         String
  gender       String
  name         String
  bio          String?     @default("Это пользователь не хочет о себе рассказывать")
  email        String      @unique
  login        String      @unique
  password     String
  phone        String
  lastName     String
  rating       Float
  location     String
  status       String
  statusChat   String
  registeredAt DateTime    @default(now())
  client       Client?
  freelancer   Freelancer?
  picture      Picture?
  messages     Chat[]
}

model Freelancer {
  userId       Int               @unique
  pricePerHour Int
  experience   Int
  category     String
  earning      Int
  favorites    Favorite[]
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       FreelancerSkill[]
  orders       Order[]
  responses    Response[]
  favoriteOrders FavoriteOrder[]
}

model Client {
  userId    Int        @unique
  spending  Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites Favorite[]
  orders    Order[]
}
